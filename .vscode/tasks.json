{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake-build",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "${command:cmake.buildDirectory}"
      ],
      "options": { "cwd": "${workspaceFolder}/campus-rpg" },
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "cmake-test",
      "type": "shell",
      "command": "ctest",
      "args": [
        "--test-dir",
        "${command:cmake.buildDirectory}",
        "--output-on-failure"
      ],
      "options": { "cwd": "${workspaceFolder}/campus-rpg" },
      "dependsOn": "cmake-build",
      "problemMatcher": []
    },
    {
      "label": "run-app",
      "type": "shell",
      "command": "${command:cmake.launchTargetPath}",
      "options": { "cwd": "${command:cmake.launchTargetDirectory}" },
      "dependsOn": "cmake-build",
      "problemMatcher": []
    }
  ]
}
