{
  "configurations": [
    {
      "name": "Win32-Qt-MinGW",
      "includePath": [
        "${workspaceFolder}/campus-rpg/src",
        "${workspaceFolder}/campus-rpg/src/core",
        "${workspaceFolder}/campus-rpg/src/data",
        "${workspaceFolder}/campus-rpg/src/manager",
        "${workspaceFolder}/campus-rpg/src/ui",
        "${workspaceFolder}/campus-rpg/build",
        "${env:QT_DIR}/include",
        "${env:QT_DIR}/include/QtCore",
        "${env:QT_DIR}/include/QtGui",
        "${env:QT_DIR}/include/QtWidgets",
        "${env:QT_DIR}/include/QtSql",
        "${env:QT_DIR}/include/QtTest"
      ],
      "defines": [
        "QT_CORE_LIB",
        "QT_GUI_LIB",
        "QT_WIDGETS_LIB",
        "QT_SQL_LIB",
        "UNICODE",
        "_UNICODE"
      ],
      "compilerPath": "${env:QT_MINGW_BIN}/g++.exe",
      "cStandard": "c17",
      "cppStandard": "c++20",
      "intelliSenseMode": "windows-gcc-x64"
    }
  ],
  "version": 4
}
