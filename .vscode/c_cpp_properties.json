{
  "configurations": [
    {
      "name": "Win32-MinGW",
      "includePath": [
        "${workspaceFolder}/campus-rpg/src",
        "${workspaceFolder}/campus-rpg/src/core",
        "${workspaceFolder}/campus-rpg/src/data",
        "${workspaceFolder}/campus-rpg/src/manager",
        "${workspaceFolder}/campus-rpg/src/engine/interfaces",
        "${workspaceFolder}/campus-rpg/src/scenes",
        "${workspaceFolder}/campus-rpg/build",
        "${workspaceFolder}/campus-rpg/build/_deps/sfml-src/include",
        "${workspaceFolder}/campus-rpg/build/_deps/sqlite3-src"
      ],
      "defines": [
        "UNICODE",
        "_UNICODE"
      ],
      "compilerPath": "${env:MINGW_BIN}/g++.exe",
      "cStandard": "c17",
      "cppStandard": "c++20",
      "intelliSenseMode": "windows-gcc-x64"
    }
  ],
  "version": 4
}
