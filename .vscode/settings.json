{
  "//": "Shared VS Code workspace settings for CampusRPG. Set MINGW_BIN to your MinGW bin directory (e.g. E:/Qt/Tools/mingw1310_64/bin) for IntelliSense and build tasks.",

  "cmake.sourceDirectory": "${workspaceFolder}/campus-rpg",
  "cmake.buildDirectory": "${workspaceFolder}/campus-rpg/build",
  "cmake.configureOnOpen": true,

  "cmake.generator": "MinGW Makefiles",
  "cmake.configureSettings": {
    "CMAKE_BUILD_TYPE": "Release",
    "CMAKE_EXPORT_COMPILE_COMMANDS": true,
    "CMAKE_C_COMPILER": "${env:MINGW_BIN}/gcc.exe",
    "CMAKE_CXX_COMPILER": "${env:MINGW_BIN}/g++.exe"
  },
  "cmake.environment": {
    "CXX": "${env:MINGW_BIN}/g++.exe"
  },

  "C_Cpp.default.cppStandard": "c++20",
  "C_Cpp.default.intelliSenseMode": "windows-gcc-x64",

  "files.associations": {
    "*.h": "cpp"
  },
  "search.exclude": {
    "**/build": true,
    "**/build-vs": true,
    "**/_deps": true
  },

  "extensions.recommendations": [
    "ms-vscode.cpptools",
    "ms-vscode.cmake-tools",
    "ms-vscode.cpptools-extension-pack"
  ]
}
