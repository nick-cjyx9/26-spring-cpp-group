{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug CampusRPG (MinGW/gdb)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/campus-rpg/build/CampusRPG.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/campus-rpg/build",
      "environment": [],
      "externalConsole": true,
      "MIMode": "gdb",
      "miDebuggerPath": "${env:MINGW_BIN}/gdb.exe",
      "setupCommands": [
        {
          "text": "-enable-pretty-printer",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "cmake-build"
    },
    {
      "name": "Debug CampusRPGTests (MinGW/gdb)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/campus-rpg/build/tests/CampusRPGTests.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/campus-rpg/build/tests",
      "environment": [],
      "externalConsole": true,
      "MIMode": "gdb",
      "miDebuggerPath": "${env:MINGW_BIN}/gdb.exe",
      "setupCommands": [
        {
          "text": "-enable-pretty-printer",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "cmake-build"
    }
  ]
}
